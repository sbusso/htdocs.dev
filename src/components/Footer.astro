---
const currentYear = new Date().getFullYear();

export interface Props {
  noMarginTop?: boolean;
}

const { noMarginTop = false } = Astro.props;
---

<footer class={`${noMarginTop ? "" : "mt-auto"}`}>
  <div class="footer-wrapper">
    <div class="footer-brand">
      <span class="footer-mark">&lt;/&gt;</span>
      <span class="footer-name">htdocs.dev</span>
    </div>
    <div class="footer-nav">
      <a href="/posts">Posts</a>
      <a href="/tags">Tags</a>
      <a href="/about">About</a>
      <a href="/rss.xml">RSS</a>
    </div>
    <div class="footer-contact">
      <a href="https://github.com/sbusso" rel="noopener" class="footer-social" aria-label="GitHub">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23A11.52 11.52 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.29-1.552 3.297-1.23 3.297-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"></path></svg>
      </a>
      <a href="https://twitter.com/sbusso" rel="noopener" class="footer-social" aria-label="Twitter">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
      </a>
      <a href="https://www.linkedin.com/in/stephanebusso/" rel="noopener" class="footer-social" aria-label="LinkedIn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
      </a>
    </div>
    <div class="footer-meta">&copy; {currentYear} Stephane Busso</div>
  </div>
</footer>

<style>
  footer {
    @apply w-full;
    border-top: 1px solid var(--border-light);
    max-width: 1080px; margin-left: auto; margin-right: auto; padding: 0 32px;
  }
  .footer-wrapper {
    display: flex; flex-direction: column; align-items: center;
    gap: 16px; padding: 40px 0 32px; text-align: center;
  }
  .footer-brand { display: flex; align-items: center; gap: 8px; }
  .footer-mark {
    font-family: "JetBrains Mono Variable", monospace;
    font-size: 0.6rem; font-weight: 700;
    color: var(--bg); background: var(--accent);
    width: 20px; height: 20px; border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    opacity: 0.8;
  }
  .footer-name {
    font-family: "Space Grotesk Variable", sans-serif;
    font-size: 0.82rem; font-weight: 600; color: var(--text-muted);
  }
  .footer-nav { display: flex; flex-wrap: wrap; justify-content: center; gap: 6px 20px; }
  .footer-nav a { font-size: 0.82rem; color: var(--text-muted); text-decoration: none; transition: color 0.2s; }
  .footer-nav a:hover { color: var(--text); }
  .footer-contact { display: flex; align-items: center; gap: 14px; }
  .footer-social { color: var(--text-faint); display: flex; transition: color 0.2s; }
  .footer-social:hover { color: var(--text-muted); }
  .footer-social svg { width: 16px; height: 16px; }
  .footer-meta {
    font-family: "JetBrains Mono Variable", monospace;
    font-size: 0.62rem; color: var(--text-faint); letter-spacing: 0.04em;
  }
</style>
