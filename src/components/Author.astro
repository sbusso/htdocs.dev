---
import Socials from "@components/Socials.astro";
---

<div class="author-container">
    <hr class="hr-line" />
    <div class="author-content">
        <div class="author-image">
            <img src="/author.png" alt="Stephane Busso" />
        </div>
        <div class="author-info">
            <div class="author-name">Stephane Busso</div>
            <p class="author-bio">
                Software builder and engineering manager based in Thailand 🇹🇭.
                HTDOCS.dev is a space to share about AI, technologies and engineering.
            </p>
            <div class="social-links-wrapper">
                <Socials />
            </div>
        </div>
    </div>
</div>

<style>
.author-container {
    margin-top: 3rem;
    margin-bottom: 2rem;
}
.author-content {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding-top: 2rem;
}
.author-image img {
    width: 5rem;
    height: 5rem;
    border-radius: 50%;
    border: 2px solid var(--border);
}
.author-info {
    flex: 1;
}
.author-name {
    font-family: "Space Grotesk Variable", sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
}
.author-bio {
    margin-top: 0.5rem;
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.65;
}
.social-links-wrapper {
    margin-top: 0.75rem;
}

@media (max-width: 640px) {
    .author-content {
        flex-direction: column;
    }
}
</style>
