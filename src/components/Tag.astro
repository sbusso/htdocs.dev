---
export interface Props {
  name: string;
  size?: "sm" | "lg";
}

const { name, size = "sm" } = Astro.props;
---

<li class={`tag-item ${size === "lg" ? "tag-lg" : ""}`}>
  <a
    href={`/tags/${name.toLowerCase()}`}
    transition:name={name.toLowerCase()}
    class="tag-link"
  >
    <span class="tag-hash">#</span>{name.toLowerCase()}
  </a>
</li>

<style>
  .tag-item {
    display: inline-block;
  }
  .tag-link {
    display: inline-block;
    font-family: "JetBrains Mono Variable", monospace;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    padding: 3px 10px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--bg-paper);
    transition: all 0.15s;
    letter-spacing: 0.02em;
  }
  .tag-link:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--bg-accent-soft, var(--bg-paper));
  }
  .tag-hash {
    opacity: 0.4;
    margin-right: 1px;
  }
  .tag-lg .tag-link {
    font-size: 0.82rem;
    padding: 5px 14px;
  }
</style>
