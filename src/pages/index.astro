---
import Card from "@components/Card";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import getSortedPosts from "@utils/getSortedPosts";
import slugify, { slugifyStr } from "@utils/slugify";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

const tagCounts: Record<string, number> = {};
posts.forEach(({ data }) => {
  data.tags?.forEach((tag: string) => {
    const t = slugifyStr(tag);
    tagCounts[t] = (tagCounts[t] || 0) + 1;
  });
});
const topTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10)
  .map(([name]) => name);

const faqs = [
  {
    question: "How to use Claude Code effectively?",
    answer: "Claude Code is Anthropic's CLI tool for AI-assisted development. Learn best practices including sub-agents, skills, hooks, and full-stack configuration to supercharge your workflow.",
    link: "/posts/how-to-use-claude-code",
  },
  {
    question: "What are the best open-source workflow orchestration tools in 2026?",
    answer: "Top tools include n8n, Dagster, Prefect, Kestra, and Argo Workflows. Each excels in different areas from low-code automation to data pipeline orchestration.",
    link: "/posts/the-10-best-open-source-projects-for-workflow-orchestration-and-automation",
  },
  {
    question: "What is the modern Python data stack?",
    answer: "The modern Python data stack in 2026 combines tools like Dagster, dbt, Great Expectations, and DuckDB for orchestration, transformation, quality, and analytics.",
    link: "/posts/the-modern-python-data-stack-in-2026",
  },
  {
    question: "What are the best backend-as-a-service platforms?",
    answer: "Leading open-source BaaS options include Appwrite, Supabase, Payload CMS, Directus, and Convex — offering auth, databases, storage, and APIs out of the box.",
    link: "/posts/backend-as-a-service",
  },
  {
    question: "How to get started with web scraping in Python?",
    answer: "Python offers powerful scraping tools: Scrapy for large-scale crawling, BeautifulSoup with Requests for quick scripts, and Parsel for lightweight parsing with CSS and XPath selectors.",
    link: "/posts/web-scraping-scrapy-vs-beautifulsouprequests",
  },
];

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
});
---

<Layout>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={faqJsonLd} />
  </Fragment>
  <Header />
  <main id="main-content">
    <!-- ── Hero ── -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-content">
          <div class="hero-tag">
            <span class="hero-dot"></span>
            // a resource hub
          </div>
          <h1>
            Building the future of <mark>agent&nbsp;engineering</mark>.
          </h1>
          <p class="hero-sub">
            From agent design to production — patterns, tools, and systems.
          </p>
          <div class="hero-cta">
            <a href="/posts" class="btn-primary">Curated guides</a>
            <a href="/about" class="btn-outline">About me</a>
          </div>
        </div>
        <div class="hero-terminal">
          <div class="term-window">
            <div class="term-bar">
              <span class="dot r"></span><span class="dot y"></span><span
                class="dot g"></span>
              <span class="term-title">~/agent-workflows</span>
            </div>
            <div class="term-body" id="term-anim">
              <div class="term-cursor"></div>
            </div>
          </div>
        </div>
        <script>
          (function () {
            // Claude Code style: prompt (user), thinking (block bg), output (answer)
            var lines = [
              { type: 'cmd', spans: [['> ', 'c-prompt'], ['Build an auth system with subagents', 'c-input']] },
              { type: 'think', spans: [['Analyzing codebase structure...', 'c-thinking']] },
              { type: 'think', spans: [['Found 12 files in src/auth/', 'c-thinking']] },
              { type: 'think', spans: [['Planning agent delegation strategy', 'c-thinking']] },
              { type: 'out', spans: [['Spawning subagent: code-explorer', 'c-output']] },
              { type: 'out', spans: [['Worktree isolated: feature/auth-v2', 'c-output']] },
              { type: 'out', spans: [['4 tools loaded (read, write, edit, bash)', 'c-output']] },
              { type: 'blank' },
              { type: 'cmd', spans: [['> ', 'c-prompt'], ['Wire up the lifecycle hooks', 'c-input']] },
              { type: 'think', spans: [['Reading hook configuration...', 'c-thinking']] },
              { type: 'think', spans: [['Checking 18 available hook events', 'c-thinking']] },
              { type: 'out', spans: [['PreToolUse  \u2192 validate permissions', 'c-output']] },
              { type: 'out', spans: [['PostToolUse \u2192 collect lineage', 'c-output']] },
              { type: 'out', spans: [['Stop        \u2192 run verification', 'c-output']] },
              { type: 'blank' },
              { type: 'cmd', spans: [['> ', 'c-prompt'], ['Hand off to reviewer agent', 'c-input']] },
              { type: 'think', spans: [['Compacting context (78% used)...', 'c-thinking']] },
              { type: 'think', spans: [['Preserving session across handoff', 'c-thinking']] },
              { type: 'out', spans: [['Delegating: architect \u2192 reviewer', 'c-output']] },
              { type: 'bar', filled: 14, empty: 4, pct: 78 },
              { type: 'out', spans: [['Review complete \u2014 0 issues', 'c-output']] },
              { type: 'out', spans: [['Ready.', 'c-output']] },
            ];

            var el = document.getElementById('term-anim');
            if (!el) return;

            var MAX_VISIBLE = 8;
            var TYPE_SPEED = 28;
            var LINE_PAUSE = 350;
            var CMD_PAUSE = 600;
            var BLOCK_PAUSE = 1400;
            var RESTART_PAUSE = 3000;

            var lineEls = [];
            var cursor = el.querySelector('.term-cursor');

            function createLine() {
              var div = document.createElement('div');
              div.style.opacity = '0';
              div.style.transform = 'translateY(4px)';
              div.style.transition = 'opacity 0.25s, transform 0.25s';
              el.insertBefore(div, cursor);
              lineEls.push(div);
              requestAnimationFrame(function () {
                div.style.opacity = '1';
                div.style.transform = 'translateY(0)';
              });
              while (lineEls.length > MAX_VISIBLE) {
                var old = lineEls.shift();
                old.style.opacity = '0';
                old.style.transform = 'translateY(-4px)';
                setTimeout(function (node) { node.remove(); }, 250, old);
              }
              return div;
            }

            function renderSpans(div, spans) {
              spans.forEach(function (s) {
                var span = document.createElement('span');
                span.className = s[1];
                span.textContent = s[0];
                div.appendChild(span);
              });
            }

            function typeSpans(div, spans) {
              return new Promise(function (resolve) {
                // Build all spans empty first, then type into them sequentially
                var spanEls = [];
                var texts = [];
                spans.forEach(function (s) {
                  var span = document.createElement('span');
                  span.className = s[1];
                  div.appendChild(span);
                  spanEls.push(span);
                  texts.push(s[0]);
                });

                var si = 0, ci = 0;
                function tick() {
                  if (si >= spanEls.length) { resolve(); return; }
                  if (ci < texts[si].length) {
                    spanEls[si].textContent += texts[si][ci];
                    ci++;
                    setTimeout(tick, TYPE_SPEED);
                  } else {
                    si++;
                    ci = 0;
                    tick();
                  }
                }
                tick();
              });
            }

            function sleep(ms) {
              return new Promise(function (r) { setTimeout(r, ms); });
            }

            async function run() {
              for (var i = 0; i < lines.length; i++) {
                var line = lines[i];
                if (line.type === 'blank') {
                  var blankDiv = createLine();
                  blankDiv.textContent = '\u00A0';
                  await sleep(BLOCK_PAUSE);
                  continue;
                }
                var div = createLine();
                if (line.type === 'think') {
                  div.className = 'c-thinking-block';
                  renderSpans(div, line.spans);
                  await sleep(LINE_PAUSE);
                } else if (line.type === 'bar') {
                  var fillSpan = document.createElement('span');
                  fillSpan.className = 'c-bar';
                  var emptySpan = document.createElement('span');
                  emptySpan.className = 'c-bar-empty';
                  var pctSpan = document.createElement('span');
                  pctSpan.className = 'c-bar';
                  div.appendChild(fillSpan);
                  div.appendChild(emptySpan);
                  div.appendChild(pctSpan);
                  var total = line.filled + line.empty;
                  // Fill to 78%
                  for (var b = 0; b < total; b++) {
                    if (b < line.filled) {
                      fillSpan.textContent += '\u2588';
                    } else {
                      emptySpan.textContent += '\u2591';
                    }
                    pctSpan.textContent = ' ' + Math.round(((Math.min(b + 1, line.filled)) / total) * 100) + '%';
                    await sleep(60);
                  }
                  pctSpan.textContent = ' ' + line.pct + '%';
                  await sleep(400);
                  // Fill remaining to 100%
                  for (var r = 0; r < line.empty; r++) {
                    fillSpan.textContent += '\u2588';
                    emptySpan.textContent = emptySpan.textContent.substring(1);
                    pctSpan.textContent = ' ' + Math.round(((line.filled + r + 1) / total) * 100) + '%';
                    await sleep(80);
                  }
                  pctSpan.textContent = ' 100%';
                  // Turn to neutral color
                  fillSpan.className = 'c-output';
                  pctSpan.className = 'c-output';
                  await sleep(LINE_PAUSE);
                } else if (line.type === 'cmd') {
                  await typeSpans(div, line.spans);
                  await sleep(CMD_PAUSE);
                } else {
                  renderSpans(div, line.spans);
                  await sleep(LINE_PAUSE);
                }
              }
              await sleep(RESTART_PAUSE);
              lineEls.forEach(function (l) {
                l.style.opacity = '0';
                l.style.transform = 'translateY(-4px)';
              });
              await sleep(500);
              lineEls.forEach(function (l) { l.remove(); });
              lineEls = [];
              run();
            }

            setTimeout(run, 800);
          })();
        </script>
      </div>
    </section>
    <!-- ── Featured (2-col grid) ── -->
    {
      featuredPosts.length > 0 && (
        <section class="posts-section">
          <div class="section-label">// featured</div>
          <h2 class="section-heading">Highlights</h2>
          <p class="section-desc">Hand-picked guides worth starting with.</p>
          <div class="cards-grid-2col">
            <a
              href="https://sbusso.github.io/claudeclaw/"
              target="_blank"
              rel="noopener"
              class="callout-card"
            >
              <div class="callout-content">
                <div class="callout-badge">Open Source Project</div>
                <div class="callout-logo-row">
                  <img
                    src="/images/claudeclaw-logo.webp"
                    alt="ClaudeClaw"
                    class="callout-logo"
                  />
                  <h3 class="callout-name">ClaudeClaw</h3>
                </div>
                <p class="callout-desc">
                  Use Claude to orchestrate agents like OpenClaw. Secured, fast, and
                  extensible.
                </p>
                <div class="callout-stats">
                  <span class="callout-stat"
                    ><span class="stat-value">&lt;10ms</span> cold start</span
                  >
                  <span class="callout-stat"
                    ><span class="stat-value">Kernel</span> sandboxed</span
                  >
                  <span class="callout-stat"
                    ><span class="stat-value">~8K</span> lines</span
                  >
                </div>
                <span class="callout-link">View project &rarr;</span>
              </div>
              <div class="callout-visual">
                <img
                  src="/images/claudeclaw-sandbox.png"
                  alt="ClaudeClaw sandbox security model"
                  class="callout-img"
                />
              </div>
            </a>
            {featuredPosts.map(({ data }) => (
              <Card
                href={`/posts/${slugify(data)}`}
                frontmatter={data}
                secHeading={false}
              />
            ))}
          </div>
        </section>
      )
    }

    <!-- ── Recent (2-col grid) ── -->
    <section class="posts-section">
      <div class="section-label">// latest</div>
      <h2 class="section-heading">Recent Posts</h2>
      <div class="cards-grid-2col">
        {
          recentPosts.map(
            ({ data }, index) =>
              index < 6 && (
                <Card
                  href={`/posts/${slugify(data)}`}
                  frontmatter={data}
                  secHeading={false}
                />
              )
          )
        }
      </div>
      <div class="all-posts-link">
        <a href="/posts">All posts <span>&rarr;</span></a>
      </div>
    </section>

    <!-- ── Topics ── -->
    <section class="topics-section">
      <div class="section-label">// topics</div>
      <h2 class="section-heading">Browse by topic</h2>
      <div class="topics-grid">
        {
          topTags.map(tag => (
            <a href={`/tags/${tag}`} class="topic-pill">
              <span class="topic-hash">#</span>
              {tag}
              <span class="topic-count">{tagCounts[tag]}</span>
            </a>
          ))
        }
      </div>
      <div class="all-posts-link" style="margin-top:1.25rem">
        <a href="/tags">All tags <span>&rarr;</span></a>
      </div>
    </section>

    <!-- ── FAQ ── -->
    <section class="faq-section">
      <div class="section-label">// faq</div>
      <h2 class="section-heading">Frequently Asked</h2>
      <div class="faq-list">
        {faqs.map(faq => (
          <details class="faq-item">
            <summary class="faq-question">{faq.question}</summary>
            <div class="faq-answer">
              <p>{faq.answer}</p>
              <a href={faq.link} class="faq-link">Read more &rarr;</a>
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- ── Quote ── -->
    <section class="quote-section">
      <div class="quote-mark" aria-hidden="true">&ldquo;</div>
      <blockquote>
        Build things, share what you learn, and <mark>don't&nbsp;wait</mark> until
        it's perfect.
      </blockquote>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* Wider homepage container — famstack uses 1080px */
  #main-content {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 40px 1rem;
  }
  @media (max-width: 640px) {
    #main-content {
      padding: 0 20px 1rem;
    }
  }

  /* ═══════ Hero ═══════ */
  .hero {
    padding: 3.5rem 0 3rem;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 48px;
    align-items: center;
  }
  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .hero-terminal {
      display: none;
    }
  }
  .hero-content {
  }
  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: "JetBrains Mono Variable", monospace;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--teal);
    letter-spacing: 0.06em;
    margin-bottom: 28px;
  }
  .hero-dot {
    width: 7px;
    height: 7px;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse-dot 2s infinite;
  }
  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }

  .hero h1 {
    font-size: clamp(2.2rem, 5vw, 3rem);
    font-weight: 500;
    line-height: 1.12;
    margin-bottom: 20px;
  }
  .hero-sub {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--text-secondary);
    margin-bottom: 28px;
  }
  .hero-cta {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent);
    color: var(--bg);
    border: none;
    padding: 10px 22px;
    border-radius: 8px;
    font-family: "Inter Variable", sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    transition: all 0.2s;
    box-shadow: 0 2px 8px color-mix(in srgb, var(--accent) 20%, transparent);
  }
  .btn-primary:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--accent) 19%, transparent);
  }
  .btn-outline {
    background: transparent;
    color: var(--text);
    border: 1.5px solid var(--border);
    padding: 10px 22px;
    border-radius: 8px;
    font-family: "Inter Variable", sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-outline:hover {
    border-color: var(--teal);
    color: var(--teal);
  }

  /* Terminal widget */
  .hero-terminal {
    margin-top: 12px;
  }
  .term-window {
    border-radius: 10px;
    overflow: hidden;
    background: var(--code-bg);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
    font-family: "JetBrains Mono Variable", monospace;
  }
  .term-bar {
    background: color-mix(in srgb, var(--code-bg) 80%, black);
    padding: 8px 12px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dot.r {
    background: #ff5f57;
  }
  .dot.y {
    background: #febc2e;
  }
  .dot.g {
    background: #28c840;
  }
  .term-title {
    font-size: 0.6rem;
    color: var(--text-muted);
    margin-left: 6px;
  }
  .term-body {
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 0.72rem;
    line-height: 1.55;
  }
  .term-body div {
    color: #cdd6f4;
  }
  /* Terminal color classes — :global() because spans are created by JS at runtime */
  #term-anim :global(.c-prompt) {
    color: #585b70;
    user-select: none;
  }
  #term-anim :global(.c-input) {
    color: #e4e4e7;
  }
  #term-anim :global(.c-thinking) {
    color: #7f849c;
    font-style: italic;
  }
  #term-anim :global(div.c-thinking-block) {
    background: rgba(127, 132, 156, 0.08);
    border-left: 2px solid rgba(127, 132, 156, 0.25);
    padding: 2px 8px;
    margin: 1px -8px;
    border-radius: 0 4px 4px 0;
  }
  #term-anim :global(.c-output) {
    color: #bac2de;
  }
  #term-anim :global(.c-bar) {
    color: #e8945a;
  }
  #term-anim :global(.c-bar-empty) {
    color: #45475a;
  }
  .term-cursor {
    display: inline-block;
    width: 7px;
    height: 14px;
    background: #585b70;
    animation: blink-cursor 1s step-end infinite;
  }
  @keyframes blink-cursor {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  #term-anim {
    height: calc(8 * 1.55em + 8 * 4px + 28px);
    overflow: hidden;
  }

  /* ═══════ Callout (inside featured grid) ═══════ */
  .callout-card {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: center;
    text-decoration: none;
    color: var(--text);
    background: color-mix(in srgb, var(--bg) 85%, black);
    border-radius: 14px;
    padding: 28px 32px;
  }
  .callout-card:hover {
    box-shadow: 0 8px 32px color-mix(in srgb, var(--accent) 8%, transparent);
  }
  @media (max-width: 768px) {
    .callout-card {
      grid-template-columns: 1fr;
      gap: 20px;
      padding: 24px 20px;
    }
  }
  .callout-badge {
    display: inline-block;
    font-family: "JetBrains Mono Variable", monospace;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 4px 10px;
    border-radius: 6px;
    margin-bottom: 14px;
  }
  .callout-logo-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
  }
  .callout-logo {
    width: 40px;
    height: 40px;
    border-radius: 8px;
  }
  .callout-name {
    font-size: 1.35rem;
    font-weight: 600;
    margin: 0;
  }
  .callout-desc {
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0 0 16px;
  }
  .callout-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 18px;
  }
  .callout-stat {
    font-family: "JetBrains Mono Variable", monospace;
    font-size: 0.72rem;
    color: var(--text-muted);
  }
  .stat-value {
    font-weight: 700;
    color: var(--text);
  }
  .callout-link {
    font-family: "Space Grotesk Variable", sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--accent);
    transition: all 0.2s;
  }
  .callout-card:hover .callout-link {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .callout-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .callout-img {
    width: 100%;
    max-width: 400px;
    border-radius: 10px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  }

  /* ═══════ Post Sections ═══════ */
  .posts-section {
    padding: 2.5rem 0;
    border-top: 1px solid var(--border-light);
  }
  .section-heading {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 500;
    margin-bottom: 8px;
  }
  .section-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 1.5rem;
    max-width: 540px;
  }

  /* 2-column card grid — famstack blog teaser style */
  .cards-grid-2col {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  @media (max-width: 640px) {
    .cards-grid-2col {
      grid-template-columns: 1fr;
    }
  }

  .all-posts-link {
    margin-top: 1.75rem;
    text-align: center;
  }
  .all-posts-link a {
    font-family: "Space Grotesk Variable", sans-serif;
