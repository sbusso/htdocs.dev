---
import Card from "@components/Card";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import LinkButton from "@components/LinkButton.astro";
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import getSortedPosts from "@utils/getSortedPosts";
import slugify from "@utils/slugify";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
---

<Layout>
  <Header />
  <main id="main-content">
    {
      featuredPosts.length > 0 && (
        <>
          <section id="featured">
            <div class="section-label">// featured</div>
            <h2 class="section-heading">Highlights</h2>
            <ul>
              {featuredPosts.map(({ data }) => (
                <Card
                  href={`/posts/${slugify(data)}`}
                  frontmatter={data}
                  secHeading={false}
                />
              ))}
            </ul>
          </section>
        </>
      )
    }

    <section id="recent-posts">
      <div class="section-label">// latest</div>
      <h2 class="section-heading">Recent Posts</h2>
      <ul>
        {
          sortedPosts
            .filter(({ data }) => !data.featured)
            .map(
              ({ data }, index) =>
                index < SITE.postPerPage && (
                  <Card
                    href={`/posts/${slugify(data)}`}
                    frontmatter={data}
                    secHeading={false}
                  />
                )
            )
        }
      </ul>
      <div class="all-posts-btn-wrapper">
        <LinkButton href="/posts">
          All Posts
          <svg xmlns="http://www.w3.org/2000/svg"
            ><path
              d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z"
            ></path>
          </svg>
        </LinkButton>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* Famstack: padding 100px top (after sticky nav) 64px bottom */
  #main-content {
    @apply mx-auto w-full max-w-3xl px-4;
    padding-top: 2rem;
    padding-bottom: 4rem;
  }

  #featured,
  #recent-posts {
    padding-bottom: 1.5rem;
    padding-top: 1.5rem;
  }
  #featured + #recent-posts {
    border-top: 1px solid var(--border-light);
    margin-top: 0.5rem;
  }

  /* Famstack section titles: clamp(1.6rem, 3vw, 2.2rem) */
  .section-heading {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 500;
    margin-bottom: 1.25rem;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .all-posts-btn-wrapper {
    margin-top: 2rem;
    text-align: center;
  }
  .all-posts-btn-wrapper a {
    font-family: "Space Grotesk Variable", sans-serif;
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--accent);
  }
  .all-posts-btn-wrapper a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
