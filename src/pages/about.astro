---
import Socials from "@components/Socials.astro";
import { SITE, SOCIALS } from "@config";
import Layout from "@layouts/Layout.astro";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";

const title = "About";
const socialCount = SOCIALS.filter(social => social.active).length;
---

<Layout title={`${title} | ${SITE.title}`}>
  <Header activeNav="about" />

  <section id="about">
    <h1>About</h1>
    <div class="about-content article-content">
      <p>
        Hey there &#128075;! <strong>Stephane Busso</strong> here, a French 🇫🇷 software
        builder and engineering leader currently based in Thailand 🇹🇭. HTDOCS.dev
        is a space to share about AI, technologies, and engineering.
      </p>
    </div>

    {
      socialCount > 0 && (
        <div class="social-wrapper">
          <span class="social-label">Find me on:</span>
          <Socials />
        </div>
      )
    }
  </section>
  <Footer />
</Layout>

<style>
  #about {
    max-width: 48rem;
    padding-top: 2rem;
    padding-bottom: 3rem;
  }
  #about h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin-bottom: 1.5rem;
  }
  .social-wrapper {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-light);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .social-label {
    font-family: "Space Grotesk Variable", sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-muted);
    white-space: nowrap;
  }
</style>
